---
import Layout from '@/layouts/Layout.astro'
import Dashboard from '@/components/dashboard/Dashboard'

const dashboardConfig = {
  apiBase: (import.meta.env.PUBLIC_API_BASE || '').replace(/\/$/, ''),
  apiKey: import.meta.env.PUBLIC_APP_API_KEY || import.meta.env.APP_API_KEY || '',
  timezone: import.meta.env.PUBLIC_APP_TIMEZONE || import.meta.env.APP_TIMEZONE || 'UTC',
}

const dashboardData = {
  timezone: dashboardConfig.timezone,
  stats: {},
  summaries: [],
  today: {},
  projectDurations: [],
  languageDurations: [],
  errors: [],
}
---

<Layout title="Waka Personal Dashboard">
  <Dashboard client:load data={dashboardData} config={dashboardConfig} />
</Layout>
