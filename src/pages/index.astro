---
import Layout from '@/layouts/Layout.astro'
import Dashboard from '@/components/dashboard/Dashboard'

const apiBase = (import.meta.env.API_PROXY_TARGET || 'http://127.0.0.1:8080').replace(/\/$/, '')
const apiKey = import.meta.env.APP_API_KEY || ''
const timezone = import.meta.env.APP_TIMEZONE || 'UTC'

const buildUrl = (path, params = {}) => {
  const url = new URL(`${apiBase}${path}`)
  for (const [k, v] of Object.entries(params)) {
    if (v != null && v !== '') url.searchParams.set(k, String(v))
  }
  if (apiKey) url.searchParams.set('api_key', apiKey)
  return url
}

const fetchJson = async (path, params = {}) => {
  try {
    const res = await fetch(buildUrl(path, params))
    if (!res.ok) return { data: null, error: `${path} returned ${res.status}` }
    return { data: await res.json(), error: null }
  } catch (e) {
    return { data: null, error: `${path} failed: ${e.message}` }
  }
}

const todayDate = new Intl.DateTimeFormat('en-CA', { timeZone: timezone }).format(new Date())

const [statsRes, summariesRes, todayRes, projDurRes, langDurRes] = await Promise.all([
  fetchJson('/api/v1/users/current/stats/last_7_days', { timezone }),
  fetchJson('/api/v1/users/current/summaries', { range: 'Last 7 Days', timezone }),
  fetchJson('/api/v1/users/current/status_bar/today'),
  fetchJson('/api/v1/users/current/durations', { date: todayDate, slice_by: 'project', timezone }),
  fetchJson('/api/v1/users/current/durations', { date: todayDate, slice_by: 'language', timezone }),
])

const errors = [statsRes.error, summariesRes.error, todayRes.error, projDurRes.error, langDurRes.error].filter(Boolean)

const dashboardData = {
  timezone,
  stats: statsRes.data?.data || {},
  summaries: summariesRes.data?.data || [],
  today: todayRes.data?.data || {},
  projectDurations: projDurRes.data?.data || [],
  languageDurations: langDurRes.data?.data || [],
  errors,
}
---

<Layout title="Waka Personal Dashboard">
  <Dashboard client:load data={dashboardData} />
</Layout>
